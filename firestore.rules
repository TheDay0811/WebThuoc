rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HÀM TIỆN ÍCH =====
    // Kiểm tra người dùng đã đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Kiểm tra user có role admin (dựa trên document users)
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Kiểm tra user là chủ sở hữu của document (userId là request.auth.uid)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===== COLLECTION: users (thông tin người dùng) =====
    // Người dùng chỉ được đọc/ghi thông tin của chính mình,
    // admin có quyền đọc tất cả.
    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===== COLLECTION: KHACH_HANG (khách hàng) =====
    // Bất kỳ ai cũng có thể đọc, chỉ admin hoặc chủ sở hữu mới ghi được.
    match /KHACH_HANG/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: QUAN_LY (admin) =====
    // Chỉ admin mới xem và sửa.
    match /QUAN_LY/{docId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: NHAN_VIEN (nhân viên) =====
    // Chỉ admin mới xem và sửa.
    match /NHAN_VIEN/{docId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: DANH_MUC (danh mục) =====
    // Mọi người đọc, chỉ admin mới sửa.
    match /DANH_MUC/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: THUOC (thuốc) =====
    // Mọi người đọc, chỉ admin mới thêm/sửa/xóa.
    match /THUOC/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: GIO_HANG (giỏ hàng) =====
    // Mỗi khách chỉ xem/ghi giỏ hàng của mình (dựa trên ma_khach_hang).
    // Nhưng ma_khach_hang lưu trong document, cần kiểm tra.
    // Lưu ý: dữ liệu của bạn dùng ma_khach_hang (là số).
    // Có thể phải map với uid, nhưng tạm thời:
    match /GIO_HANG/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // ===== COLLECTION: CHI_TIET_GIO_HANG (chi tiết giỏ) =====
    // Tương tự, cần kiểm tra người dùng sở hữu.
    match /CHI_TIET_GIO_HANG/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // ===== COLLECTION: KHUYEN_MAI (khuyến mãi) =====
    // Mọi người đọc, chỉ admin mới thêm/sửa.
    match /KHUYEN_MAI/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: DON_HANG (đơn hàng) =====
    // Mọi người có thể đọc đơn hàng, nhưng chỉ admin mới cập nhật (xác nhận, hủy...)
    match /DON_HANG/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: CHI_TIET_DON_HANG =====
    match /CHI_TIET_DON_HANG/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: THANH_TOAN =====
    match /THANH_TOAN/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: HOA_DON =====
    match /HOA_DON/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ===== COLLECTION: DANH_GIA (đánh giá) =====
    // Mọi người đọc, chỉ người dùng đã đăng nhập mới thêm, 
    // admin có quyền ẩn/hiện.
    match /DANH_GIA/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.ma_khach_hang);
    }
    
    // ===== COLLECTION: TIN_NHAN (chat) =====
    // Chỉ người đã đăng nhập mới xem tin nhắn, admin và khách hàng liên quan được gửi.
    match /TIN_NHAN/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
    
    // ===== FALLBACK: từ chối tất cả mọi thứ không được định nghĩa =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}